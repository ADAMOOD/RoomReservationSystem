<Window x:Class="RoomReservationSystem.Desktop.UserControls.Dialogs.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rooms management" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">

            <Border Background="White" CornerRadius="8" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <TextBlock Text="User" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,15"/>

                    <TextBlock Text="Username"  FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <TextBox x:Name="UserNameTB" Tag="Username" Padding="8" Margin="0,0,0,15" BorderBrush="#D1D5DB" BorderThickness="1" />


                    <TextBlock Text="Password" FontSize="13"  FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <PasswordBox Padding="8" Margin="0,0,0,5" x:Name="PasswordBox1" BorderBrush="#D1D5DB" BorderThickness="1" />
                    <TextBlock Text="Password again" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <PasswordBox Padding="8" Margin="0,0,0,5" x:Name="PasswordBox2" BorderBrush="#D1D5DB" BorderThickness="1" />
                    
                    <CheckBox Content="Is amdin" HorizontalAlignment="Center" x:Name="isAdminCB"></CheckBox>

                    <StackPanel Margin="0,10,0,0">
                        <Button x:Name="ConfirmBtn" Content="Save changes" Click="ConfirmBtn_Click" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand" FontWeight="Bold" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>