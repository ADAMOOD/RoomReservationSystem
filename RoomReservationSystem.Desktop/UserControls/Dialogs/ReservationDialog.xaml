<Window x:Class="RoomReservationSystem.Desktop.UserControls.Dialogs.ReservationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Správa rezervací" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        FontFamily="Segoe UI">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">

            <Border Background="White" CornerRadius="8" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel x:Name="ReservationsOverviewPanel" Margin="0,0,0,20" />

                    <TextBlock Text="Reservation" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,15"/>

                    <TextBlock Text="Room" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <ComboBox x:Name="RoomComboBox" Padding="8" Margin="0,0,0,5"
                              DisplayMemberPath="Name" 
                              SelectedValuePath="Id" 
                              SelectionChanged="RoomComboBox_SelectionChanged" />

                    <TextBlock x:Name="RoomHintTB" FontSize="11" FontStyle="Italic" Foreground="#6B7280" Margin="0,0,0,15" Visibility="Collapsed" />

                    <TextBlock Text="Organiser (User)" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <ComboBox x:Name="UserComboBox" Padding="8" Margin="0,0,0,15"
                              DisplayMemberPath="Username" 
                              SelectedValuePath="Id" />

                    <TextBlock Text="Purpose" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <TextBox x:Name="PurposeTB" Tag="Purpose" Padding="8" Margin="0,0,0,15" />


                    <TextBlock Text="Number of people" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <TextBox x:Name="NumberOfPeopleTB" Tag="Number of people" PreviewTextInput="NumberOnly_PreviewTextInput" Padding="8" Margin="0,0,0,15"  />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="163" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                            <xctk:DateTimePicker x:Name="StartTimePicker" 
                                                 Format="Custom" 
                                                 FormatString="dd.MM.yyyy HH:mm" 
                                                 TimeFormat="Custom" 
                                                 TimeFormatString="HH:mm"
                                                 Padding="5" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                            <xctk:DateTimePicker x:Name="EndTimePicker" 
                                                 Format="Custom" 
                                                 FormatString="dd.MM.yyyy HH:mm" 
                                                 TimeFormat="Custom" 
                                                 TimeFormatString="HH:mm"
                                                 Padding="5" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <Button x:Name="AddNextReservationBtn" Click="AddNextReservationBtn_OnClick" Content="+ Add another reservation to the queue" Background="#F3F4F6" Foreground="#374151" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10" Margin="0,0,0,10" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button x:Name="ConfirmReservationBtn" Content="Save changes" Click="ConfirmReservationBtn_Click" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand" FontWeight="Bold" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>