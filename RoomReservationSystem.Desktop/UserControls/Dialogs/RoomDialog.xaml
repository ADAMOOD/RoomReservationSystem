<Window x:Class="RoomReservationSystem.Desktop.UserControls.Dialogs.RoomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Správa místností" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">

            <Border Background="White" CornerRadius="8" Padding="25" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel x:Name="OverviewPanel" Margin="0,0,0,20" />

                    <TextBlock Text="Room" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,15"/>

                    <TextBlock Text="Room name" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <TextBox x:Name="RoomNameTB" Padding="8" Margin="0,0,0,15" BorderBrush="#D1D5DB" BorderThickness="1" />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Capacity" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                            <TextBox x:Name="CapacityTB" PreviewTextInput="NumberOnly_PreviewTextInput" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max. time (minutes)" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                            <TextBox x:Name="MaxTimeTB" PreviewTextInput="NumberOnly_PreviewTextInput" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Equipment" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5" />
                    <StackPanel x:Name="EquipmentPanel" Margin="0,0,0,25">
                        <TextBox Padding="8" Margin="0,0,0,5" BorderBrush="#D1D5DB" BorderThickness="1" PreviewTextInput="NoCommas_PreviewTextInput" TextChanged="EquipmentTB_TextChanged" />
                    </StackPanel>

                    <StackPanel Margin="0,10,0,0">
                        <Button x:Name="AddNextRoomBtn" Click="AddNextRoomBtn_OnClick" Content="+ Add another room to the queue" Background="#F3F4F6" Foreground="#374151" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10" Margin="0,0,0,10" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button x:Name="ConfirmBtn" Content="Save changes" Click="ConfirmBtn_Click" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand" FontWeight="Bold" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>