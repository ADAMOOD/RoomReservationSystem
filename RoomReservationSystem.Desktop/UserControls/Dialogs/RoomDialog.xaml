<Window x:Class="RoomReservationSystem.Desktop.UserControls.Dialogs.RoomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adding rooms" Height="500" Width="400">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="250" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel x:Name="OverviewPanel" Margin="0,0,0,20" />

                <TextBlock Text="Room name" FontSize="14" Margin="0,0,0,5" />
                <TextBox x:Name="RoomNameTB" Padding="5" Margin="0,0,0,15" />

                <TextBlock Text="Capacity"  FontSize="14" Margin="0,0,0,5" />
                <TextBox x:Name="CapacityTB" PreviewTextInput="NumberOnly_PreviewTextInput"  Padding="5" Margin="0,0,0,15" />

                <TextBlock Text="Equipment" FontSize="14" Margin="0,0,0,5" />

                <StackPanel x:Name="EquipmentPanel" Margin="0,0,0,15">
                    <TextBox Padding="5" Margin="0,0,0,5" PreviewTextInput="NoCommas_PreviewTextInput" TextChanged="EquipmentTB_TextChanged" />
                </StackPanel>

                <TextBlock Text="Maximum time (minutes)" FontSize="14" Margin="0,0,0,5" />
                <TextBox x:Name="MaxTimeTB" PreviewTextInput="NumberOnly_PreviewTextInput" Padding="5" Margin="0,0,0,20" />

                <Button x:Name="AddNextRoomBtn" Click="AddNextRoomBtn_OnClick" Content="Add another room" Margin="0,0,0,10" Padding="5" />
                <Button x:Name="ConfirmBtn" Content="Confirm" Padding="5" Click="ConfirmBtn_Click" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>