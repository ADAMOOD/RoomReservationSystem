<Window x:Class="RoomReservationSystem.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoomReservationSystem.Desktop"
        mc:Ignorable="d"
        Title="Přihlášení - Administrátor" Height="450" Width="800">
    <Grid>
        <StackPanel Width="250" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Admin Login" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20" />

            <TextBlock Text="Name" FontSize="14" Margin="0,0,0,5" />
            <TextBox x:Name="UsernameTextBox" Padding="5" Margin="0,0,0,15" />

            <TextBlock Text="Password" FontSize="14" Margin="0,0,0,5" />
            <PasswordBox x:Name="PasswordBox" Padding="5" Margin="0,0,0,20" />

            <Button x:Name="LoginButton" Content="Login" Padding="10" Background="#0078D7" Foreground="White" Click="LoginButton_Click" />

        </StackPanel>
    </Grid>
</Window>