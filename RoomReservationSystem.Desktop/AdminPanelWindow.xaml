<Window x:Class="RoomReservationSystem.Desktop.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoomReservationSystem.Desktop"
        xmlns:UserControls="clr-namespace:RoomReservationSystem.Desktop.UserControls"
        mc:Ignorable="d"
        Title="Admin Panel" Height="450" Width="800">
    <Grid>
        <TabControl >
            <TabItem Header="Users" >
                <UserControls:UsersControl x:Name="UsersTab" ></UserControls:UsersControl>
            </TabItem>
            <TabItem Header="Rooms" >
                <UserControls:RoomsControl x:Name="RoomsTab"></UserControls:RoomsControl>
            </TabItem>
            <TabItem Header="Reservations">
                <UserControls:ReservationsControl x:Name="ReservationsTab"></UserControls:ReservationsControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
